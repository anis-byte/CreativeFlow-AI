# ─── Supabase ─────────────────────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY, never exposed to the browser. Used by admin APIs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI provider ──────────────────────────────────────────────────────────────
# Which provider powers the 3 generation functions.
#   demo   → no key needed, returns canned sample output (great for first run)
#   gemini → Google Gemini free tier (set GEMINI_API_KEY below)
#   openai → OpenAI (paid; set OPENAI_API_KEY)
#   claude → Anthropic Claude (paid; set ANTHROPIC_API_KEY)
# If a provider is selected but its key is missing, the app falls back to demo mode.
AI_PROVIDER=gemini

# Model id for the selected provider (optional — sensible default per provider).
#   gemini default: gemini-2.0-flash   (free tier)
#   openai default: gpt-4o-mini
#   claude default: claude-sonnet-4-6
AI_MODEL=

# Free real-AI key from Google AI Studio (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional paid providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
# Default monthly credit limit for newly signed-up users.
DEFAULT_CREDIT_LIMIT=500
